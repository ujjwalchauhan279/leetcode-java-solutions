/* 

Time Complexity: O(n log n)
Space Complexity: O(1)
Approach:
1. first sort the array with inbuilt sort method
2. find out 1 difference K
3. check other difference between element with K and if not equal to K return false
4. return true

*/



class Solution {
    public boolean canMakeArithmeticProgression(int[] arr) {
        Arrays.sort(arr);
        int k=arr[1]-arr[0];
        for(int i=1; i<arr.length-1; i++){
            if(arr[i+1]-arr[i]!=k) return false;
        }
        return true;
    }
}
