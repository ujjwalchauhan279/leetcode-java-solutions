/* 

Time Complexity: O(log n)
Space Complexity: O(1)
Approach:
1. remove last digit from number
2. add digit to rev
3. return rev

*/


class Solution {
    public boolean isPalindrome(int x) {
        if(x<0) return false;
        int n=x;
        int rev=0;
        while(x>0){
            rev = rev*10 + x%10;
            x/=10;
        }
        return (rev==n);
    }
}
