/* 

Time Complexity: O(n)
Space Complexity: O(1)
Approach:
1. iterate over array
2. XOR each element with next element
3. XOR has a property that for same number , XOR return 0 and with unique number XOR 0 gives that number
4. return the number

*/


class Solution {
    public int singleNumber(int[] nums) {
        int ans=0;
        for(int i=0; i<nums.length; i++){
            ans^= nums[i];
        }
    return ans;
    }
}
