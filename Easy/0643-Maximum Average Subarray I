/* 

Time Complexity: O(n)
Space Complexity: O(1)
Approach:
1. Initialize window of size k and calculate initial sum
2. Store initial average as maxsum
3. Slide the window till end of array
4. Remove left element from sum
5. Add next right element to sum
6. Update maximum average using sum / k
7. Return maximum average

*/




class Solution {
    public double findMaxAverage(int[] nums, int k) {
        int l=0;
        int r=k-1;
        double sum=0;
        for(int i=l; i<=r; i++) sum+=nums[i];
        double maxsum = sum/k;
        while(r<nums.length-1){
            sum-=nums[l];
            l++;
            r++;
            sum+=nums[r];
            maxsum = Math.max(maxsum, sum/k);
        }
        return maxsum;
    }
}
