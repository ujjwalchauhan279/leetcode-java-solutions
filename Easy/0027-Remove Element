/* 

Time Complexity: O(n)
Space Complexity: O(1)
Approach:
1. Initialize a pointer count = 0
2. Traverse the array from index 0 to n-1
3. If current element is not equal to val:
4. Place it at index count
5. Increment count
6. Continue till end
7. Return count (new length of array)

*/




class Solution {
    public int removeElement(int[] nums, int val) {
        int count=0;
        for(int i =0 ;i<nums.length;i++){
            if(nums[i]!=val){
                nums[count]=nums[i];
                count++;
            }
        }
        return count;
    }
}
