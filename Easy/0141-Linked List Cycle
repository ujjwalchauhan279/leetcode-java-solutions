/* 

Time Complexity: O(n)
Space Complexity: O(1)
Approach: 

Slow & Fast (Two Pointers) approach

1. slow moves one step and fast moves two steps
2. if their is loop in list then definitely slow and fast meets at a point, return true
3. if we reach to null or fast.next is null then surely their is no loop , return false

*/


/**
 * Definition for singly-linked list.
 * class ListNode {
 *     int val;
 *     ListNode next;
 *     ListNode(int x) {
 *         val = x;
 *         next = null;
 *     }
 * }
 */
public class Solution {
    public boolean hasCycle(ListNode head) {
        ListNode slow = head;
        ListNode fast = head;
        while(fast!=null && fast.next!=null){
            slow = slow.next;
            fast = fast.next.next;
            if(slow==fast) return true;
        }
        return false;
    }
}
