/* 

Time Complexity: O(n)
Space Complexity: O(1)
Approach:
1. Initialize window of size k and compute initial sum
2. Check if (sum / k) ≥ threshold → increment count
3. Slide the window till end
4. Remove left element and add next right element
5. Check condition again for each window
6. Return count

*/





class Solution {
    public int numOfSubarrays(int[] arr, int k, int threshold) {
        int l=0;
        int r=k-1;
        int sum=0;
        int count=0;
        for(int i=l; i<=r; i++) sum+=arr[i];
        if((sum/k)>=threshold) count++;
        while(r<arr.length-1){
            sum-=arr[l];
            l++;
            r++;
            sum+=arr[r];
            if((sum/k)>=threshold) count++;
        }
        return count;
    }
}
