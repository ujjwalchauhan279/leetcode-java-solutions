/* 

Time Complexity: O(n)
Space Complexity: O(n)
Approach:
1. Use two pointers l = 0, r = 0
2. Use a HashMap to store last index of each character
3. Traverse string using r
4. If character already exists in map and its index ≥ l:
5. Move l to lastIndex + 1
6. Update current character’s index in map
7. Update maxlen = max(maxlen, r - l + 1)
8. Move r++
9. Return maxlen

*/




class Solution {
    public int lengthOfLongestSubstring(String s) {
        HashMap<Character,Integer> map = new HashMap<>();
        int l=0;
        int r=0;
        int maxlen=0;
        while(r<s.length()){
            if(map.containsKey(s.charAt(r)) && (map.get(s.charAt(r)) >= l)){
                l=map.get(s.charAt(r)) + 1;
            }
            map.put(s.charAt(r),r);
            maxlen=(int)Math.max(maxlen, r-l+1);
            r++;
        }
        return maxlen;
    }
}
