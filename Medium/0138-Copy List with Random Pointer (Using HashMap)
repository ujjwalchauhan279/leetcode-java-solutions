/* 

Time Complexity: O(n)
Space Complexity: O(n)
Approach:
1. Create a deep copy of the linked list (only next pointers)
2. Create a HashMap to map original nodes → copied nodes
3. Store mapping for each node (original → copy)
4. Also map null → null to handle edge case
5. Traverse original list again
6. Set random pointer of copied node using map:
7. copy.random = map.get(original.random)
8. Return head of copied list

*/





class Solution {
    public Node copyRandomList(Node head1) {
        if(head1==null) return null;
        Node head2 = new Node(head1.val);
        Node temp1 = head1.next;
        Node temp2 = head2;

        //deepcopy of singly linklist
        while(temp1!=null){
            Node a = new Node(temp1.val);
            temp2.next = a;
            temp1=temp1.next;
            temp2=temp2.next;
        }

        //Make hashmap for to store nodes of both list
        HashMap<Node,Node> map = new HashMap<>();
        temp1 = head1;
        temp2 = head2;
        map.put(null,null);
        while(temp1!=null){
            map.put(temp1,temp2);
            temp1 = temp1.next;
            temp2 = temp2.next;
        }

        //connect random using hashmap and return head2
        temp1 = head1;
        while(temp1!=null){
            map.get(temp1).random = map.get(temp1.random);
            temp1 = temp1.next;
        }
        return head2;
    }
}
