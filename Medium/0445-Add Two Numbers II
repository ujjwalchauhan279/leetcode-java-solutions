/* 

Time Complexity: O(n+m)
Space Complexity: O(n+m)
Approach:
1. Dono linked lists ko reverse karo.
2. Digit-by-digit addition karo with carry.
3. Result list build karo using dummy node.
4. End me result list ko reverse karke return karo.

*/


class Solution {
    public ListNode reverse(ListNode head) {
        ListNode curr = head;
        ListNode prev = null;
        ListNode fwd = null;
        while (curr != null) {
            fwd = curr.next;
            curr.next = prev;
            prev = curr;
            curr = fwd;
        }
        return prev;
    }

    public ListNode addTwoNumbers(ListNode l1, ListNode l2) {
        l1=reverse(l1);
        l2=reverse(l2);
        int sum=0,carry=0;
        ListNode ans = new ListNode(-1);
        ListNode temp=ans;
        while(l1!=null && l2!=null){
            sum = l1.val + l2.val + carry;
            if(sum>9){
                ListNode a = new ListNode(sum%10);
                temp.next=a;
                carry=1;
            }
            else{
                ListNode a = new ListNode(sum);
                temp.next=a;
                carry=0;
            }
            l1=l1.next;
            l2=l2.next;
            temp=temp.next;
        }
        while(l1!=null){
            sum = l1.val + carry;
            if(sum>9){
                ListNode a = new ListNode(sum%10);
                temp.next=a;
                carry=1;
            }
            else{
                ListNode a = new ListNode(sum);
                temp.next=a;
                carry=0;
            }
            l1=l1.next;
            temp=temp.next;
        }
        while(l2!=null){
            sum = l2.val + carry;
            if(sum>9){
                ListNode a = new ListNode(sum%10);
                temp.next=a;
                carry=1;
            }
            else{
                ListNode a = new ListNode(sum);
                temp.next=a;
                carry=0;
            }
            l2=l2.next;
            temp=temp.next;
        }
        if(carry==1){
            ListNode a = new ListNode(carry);
            temp.next=a;
        }
        ans=ans.next;
        return reverse(ans);
    }
}
